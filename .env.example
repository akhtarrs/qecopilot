# QE-Copilot Framework — .env Template
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
#
# Single-environment rule: this project targets ONE environment.
# Set BASE_URL and API_URL to whichever environment you are testing.
# To test a different environment, scaffold a separate project folder.

# ── Active URLs (used by all actions and API checks at runtime) ────
BASE_URL=https://your-app.example.com
API_URL=https://your-app.example.com/api

# ── User Credentials ──────────────────────────────────────────────
# Add one block per persona used in your test cases.
# Reference in testdata/users.yml as ${env.ADMIN_USER} etc.

ADMIN_USER=admin_user
ADMIN_PASSWORD=admin_secret

STANDARD_USER=standard_user
STANDARD_PASSWORD=user_secret

# MANAGER_USER=manager_user
# MANAGER_PASSWORD=manager_secret
